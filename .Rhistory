load("E:/Sem 6/Prob & Stats/kazim/.RData")
install.packages("readxl")
library(readxl)
data <- read_excel("file2.xlsx")
data <- read_excel("file2.xlsx")
colnames(data)
survey_data <- data[, 8:ncol(data)]
likert_map <- c(
"Strongly disagree" = 1,
"Disagree" = 2,
"Neutral" = 3,
"Agree" = 4,
"Strongly agree" = 5,
" agree" = 4,
" Agree" = 4,
" disagree" = 2,
" Disagree" = 2,
" neutral" = 3,
" Neutral" = 3,
" Strongly agree" = 5,
" Strongly disagree" = 1
)
# Apply the mapping to convert text to numeric
scored_data <- as.data.frame(lapply(survey_data, function(col) as.numeric(likert_map[as.character(col)])))
# Calculate mean and standard deviation for each question
mean_sd <- data.frame(
Question = colnames(scored_data),
Mean = round(colMeans(scored_data, na.rm = TRUE), 2),
SD = round(apply(scored_data, 2, sd, na.rm = TRUE), 2)
)
# Print results
print(mean_sd)
# formatted
# Format mean_sd into a clean table-like output
cat(sprintf("%-100s %6s %6s\n", "Question", "Mean", "SD"))
cat(strrep("-", 120), "\n")
for (i in 1:nrow(mean_sd)) {
cat(sprintf("%-100s %6.2f %6.2f\n",
mean_sd$Question[i],
mean_sd$Mean[i],
mean_sd$SD[i]))
}
# only with question numbers
# Format output with only Question Numbers
cat(sprintf("%-10s %6s %6s\n", "Question", "Mean", "SD"))
cat(strrep("-", 30), "\n")
for (i in 1:nrow(mean_sd)) {
cat(sprintf("Q%-9d %6.2f %6.2f\n", i, mean_sd$Mean[i], mean_sd$SD[i]))
}
